# Server
PORT=8080
DB_PATH=data.db

# Telegram Bot (optional — leave blank to disable)
# Create a bot via @BotFather on Telegram
TG_BOT_TOKEN=

# Web Push / VAPID (optional — leave blank to disable)
# Generate keys: npx web-push generate-vapid-keys
# Or: go run github.com/SherClockHolmes/webpush-go/cmd/generate-key@latest
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
